
# for alias making
alias palias='cat ~/Documents/alias/alias'
alias s='source ~/Documents/alias/alias && source ~/Documents/alias/alias_convenience && source ~/Documents/alias/alias_git && source ~/Documents/alias/alias_programs && source ~/Documents/alias/alias_systemd && source ~/Documents/alias/alias_work'
alias e='vim ~/Documents/alias/alias'

# alias files
alias pgit='cat ~/Documents/alias/alias_git'
alias pprograms='cat ~/Documents/alias/alias_programs'
alias pconvenience='cat ~/Documents/alias/alias_convenience'
alias psystemd='cat ~/Documents/alias/alias_systemd'
alias pwork='cat ~/Documents/alias/alias_work'


. "$HOME/Documents/alias/alias_programs" 
. "$HOME/Documents/alias/alias_convenience"
. "$HOME/Documents/alias/alias_git" 
. "$HOME/Documents/alias/alias_work"
. "$HOME/Documents/alias/alias_systemd"


# make kill code ctrl+k instead of ctrl+c
stty intr ^K



# commands that run on terminal startup
public_ip