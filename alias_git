. "$HOME/Documents/alias/git_scripts/repo" # repo
. "$HOME/Documents/alias/git_scripts/delete_branch" # delete_branch
. "$HOME/Documents/alias/git_scripts/git_fix" # git_fix
. "$HOME/Documents/alias/git_scripts/save" # save


